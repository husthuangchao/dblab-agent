# Copy to .env and fill in your LLM key.  cp .env.example .env

# ── LLM (any OpenAI-compatible /v1/chat/completions endpoint) ──────────────
# DeepSeek (default):
DBLAB_LLM_API_KEY=sk-your-key-here
DBLAB_LLM_BASE_URL=https://api.deepseek.com/v1/chat/completions
DBLAB_LLM_MODEL=deepseek-chat
#
# OpenAI:        https://api.openai.com/v1/chat/completions          gpt-4o-mini
# Qwen/DashScope https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions  qwen-plus
# Local Ollama:  http://localhost:11434/v1/chat/completions          qwen2.5  (any key)

# ── Vision / multimodal model (handles uploaded screenshots) ───────────────
# Defaults to Zhipu GLM-4V. You can also set these from the /admin page.
DBLAB_VISION_API_KEY=
DBLAB_VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
DBLAB_VISION_MODEL=glm-4v-plus

# Optional: protect the /admin settings page. Empty = open (local demo only).
DBLAB_ADMIN_TOKEN=

# ── Host ports to publish (change if these are already taken on your machine) ──
# APP_PUBLISH=9527
# PG_PUBLISH=5432
# MYSQL_PUBLISH=3306
# OPENGAUSS_PUBLISH=5433

# ── openGauss demo password (8-16 chars, upper+lower+digit+special) ────────
# Only change if you also change it everywhere; the default works out of the box.
OPENGAUSS_PASSWORD=Gauss@bcd1234

# ── Connecting to your OWN databases instead of the bundled demo ───────────
# (uncomment + edit, or just add connections in the UI)
# PG_HOST=127.0.0.1
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=postgres
# PG_DB=demo
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=mysql
# MYSQL_DB=demo
